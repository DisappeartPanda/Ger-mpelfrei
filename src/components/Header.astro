---
const nav = [
  { href: "/leistungen", label: "Leistungen" },
  { href: "/ueber-uns", label: "Über uns" },
  { href: "/kontakt", label: "Kontakt" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a
      href="/"
      class="brand"
      aria-label="Zur Startseite von Haushaltsauflösungs Helfer Hannover"
    >
      <img
        src="/HHH-mit-schrift-logo.svg"
        alt="Haushaltsauflösungs Helfer Hannover Logo"
        class="brand-logo"
      />

      <div class="brand-text">
        <div class="brand-title">Haushaltsauflösungs Helfer Hannover</div>
        <div class="brand-subtitle">
          Entrümpelung · Haushaltsauflösung · Nachlassräumung
        </div>
      </div>
    </a>

    <div class="desktop-nav-wrap">
      <nav class="main-nav" aria-label="Hauptnavigation">
        {nav.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <a href="/kontakt" class="nav-cta">Angebot anfragen</a>
    </div>

    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menü öffnen"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
    <nav class="mobile-nav" aria-label="Mobile Navigation">
      {nav.map((item) => (
        <a href={item.href} class="mobile-link">{item.label}</a>
      ))}
      <a href="/kontakt" class="mobile-cta">Angebot anfragen</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  if (toggle && mobileMenu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      mobileMenu.hidden = isOpen;
      toggle.classList.toggle("is-open", !isOpen);
      document.body.classList.toggle("menu-open", !isOpen);
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        mobileMenu.hidden = true;
        toggle.classList.remove("is-open");
        document.body.classList.remove("menu-open");
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(12px) saturate(160%);
    border-bottom: 1px solid rgba(29, 39, 51, 0.08);
  }

  .header-inner {
    min-height: 92px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    min-width: 0;
    flex: 1 1 auto;
  }

  .brand-logo {
    width: 7rem;
    height: 7rem;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
    background: transparent;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .brand-title {
    font-size: 1.02rem;
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #1d2733;
  }

  .brand-subtitle {
    margin-top: 4px;
    font-size: 0.82rem;
    line-height: 1.25;
    font-weight: 600;
    color: rgba(29, 39, 51, 0.72);
  }

  .desktop-nav-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 11px;
    border-radius: 999px;
    text-decoration: none;
    color: #1d2733;
    font-size: 0.96rem;
    font-weight: 700;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }

  .nav-link:hover {
    background: rgba(29, 39, 51, 0.06);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 17px;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 800;
    background: linear-gradient(135deg, #7dbf76 0%, #67b45f 100%);
    box-shadow: 0 8px 20px rgba(103, 180, 95, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 26px rgba(103, 180, 95, 0.26);
  }

  .menu-toggle {
    display: none;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(29, 39, 51, 0.1);
    border-radius: 14px;
    background: #fff;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .menu-toggle span {
    width: 20px;
    height: 2px;
    background: #1d2733;
    border-radius: 999px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-toggle.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.is-open span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    border-top: 1px solid rgba(29, 39, 51, 0.08);
    background: rgba(255, 255, 255, 0.98);
  }

  .mobile-nav {
    width: min(100% - 32px, 1200px);
    margin: 0 auto;
    padding: 14px 0 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mobile-link {
    text-decoration: none;
    color: #1d2733;
    font-size: 1rem;
    font-weight: 700;
    padding: 12px 14px;
    border-radius: 14px;
  }

  .mobile-link:hover {
    background: rgba(29, 39, 51, 0.05);
  }

  .mobile-cta {
    margin-top: 6px;
    text-decoration: none;
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    padding: 13px 16px;
    border-radius: 16px;
    text-align: center;
    background: linear-gradient(135deg, #7dbf76 0%, #67b45f 100%);
    box-shadow: 0 8px 20px rgba(103, 180, 95, 0.2);
  }

  @media (max-width: 1180px) {
    .header-inner {
      min-height: 86px;
      gap: 14px;
    }

    .brand-logo {
      width: 56px;
      height: 56px;
    }

    .brand-title {
      font-size: 0.96rem;
    }

    .brand-subtitle {
      font-size: 0.78rem;
    }

    .nav-link {
      padding: 8px 9px;
      font-size: 0.92rem;
    }

    .nav-cta {
      padding: 10px 14px;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 980px) {
    .desktop-nav-wrap {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .mobile-menu {
      display: block;
    }

    .mobile-menu[hidden] {
      display: none;
    }

    .brand {
      flex: 1 1 auto;
      min-width: 0;
    }

    .brand-title {
      font-size: 0.95rem;
    }

    .brand-subtitle {
      font-size: 0.77rem;
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      min-height: 78px;
      gap: 12px;
    }

    .brand {
      gap: 12px;
    }

    .brand-logo {
      width: 48px;
      height: 48px;
    }

    .brand-title {
      font-size: 0.9rem;
      line-height: 1.12;
    }

    .brand-subtitle {
      font-size: 0.74rem;
      line-height: 1.25;
    }

    .menu-toggle {
      width: 44px;
      height: 44px;
      border-radius: 12px;
    }
  }
</style>