---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import "../styles/global.css";

const whatsappNumber = "491772186997";
const whatsappMessage =
  "Hallo, ich benötige eine Entrümpelung / Haushaltsauflösung in Hannover. Können Sie mir ein Angebot machen?";
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<BaseLayout
  title="Kontakt – Haushaltsauflösungs Helfer Hannover"
  canonical="/kontakt"
  description="Schnelle Anfrage per WhatsApp für Entrümpelung und Haushaltsauflösung in Hannover."
>
  <Header />

  <section class="contact-hero">
    <div class="container contact-hero-inner">
      <div class="contact-copy">
        <div class="kicker">Kontakt</div>
        <h1>Schnell & einfach per WhatsApp anfragen</h1>
        <p class="contact-lead">
          Schick uns kurz ein paar Infos und am besten direkt Fotos. So können wir
          den Aufwand schnell einschätzen und dir oft direkt einen fairen Preis nennen.
        </p>

        <div class="contact-actions">
          <a href={whatsappHref} class="btn primary-green contact-main-cta" target="_blank" rel="noopener noreferrer">
            Per WhatsApp anfragen
          </a>
          <a href="tel:+491772186997" class="btn secondary">
            Jetzt anrufen
          </a>
        </div>

        <div class="contact-points">
          <span>✓ Schnelle Rückmeldung</span>
          <span>✓ Fotos direkt senden</span>
          <span>✓ Faire Einschätzung</span>
        </div>
      </div>

      <div class="contact-highlight">
        <div class="contact-highlight-badge">Am schnellsten</div>
        <h2>Was du uns schicken solltest</h2>

        <div class="contact-mini-steps">
          <div class="contact-mini-step">
            <strong>Fotos</strong>
            <p>Räume, Möbel und grobe Menge</p>
          </div>
          <div class="contact-mini-step">
            <strong>Infos</strong>
            <p>Stadtteil, Etage, Aufzug, Termin</p>
          </div>
          <div class="contact-mini-step">
            <strong>Ergebnis</strong>
            <p>Oft direkt eine erste Preiseinschätzung</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section kicker="Ablauf" heading="So einfach geht’s">
    <div class="simple-steps">
      <div class="simple-step">
        <div class="simple-step-number">1</div>
        <h3>WhatsApp öffnen</h3>
        <p>Ein Klick und du bist direkt im Chat mit uns.</p>
      </div>

      <div class="simple-step">
        <div class="simple-step-number">2</div>
        <h3>Fotos & Infos senden</h3>
        <p>Je genauer wir den Umfang sehen, desto besser können wir kalkulieren.</p>
      </div>

      <div class="simple-step">
        <div class="simple-step-number">3</div>
        <h3>Angebot erhalten</h3>
        <p>Wir melden uns schnell mit einer fairen Einschätzung oder einem Festpreis.</p>
      </div>
    </div>
  </Section>

  <Section kicker="Direkter Kontakt" heading="So erreichst du uns">
    <div class="contact-direct-grid">
      <a href={whatsappHref} class="direct-card direct-card-primary" target="_blank" rel="noopener noreferrer">
        <span class="direct-label">WhatsApp</span>
        <h3>0177 2186997</h3>
        <p>Der schnellste Weg für Fotos, Rückfragen und Angebotsanfragen.</p>
      </a>

      <a href="tel:+491772186997" class="direct-card">
        <span class="direct-label">Telefon</span>
        <h3>Jetzt anrufen</h3>
        <p>Ideal, wenn du dein Anliegen direkt kurz besprechen möchtest.</p>
      </a>
    </div>
  </Section>

  <Section kicker="Hinweis" heading="Gut zu wissen">
    <div class="contact-note-box">
      <p>
        Wir sind in <strong>Hannover und Umgebung</strong> im Einsatz. Wenn verwertbare
        Gegenstände vorhanden sind, prüfen wir gern, ob eine <strong>Wertanrechnung</strong>
        möglich ist.
      </p>
    </div>
  </Section>

  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    padding: 56px 0 28px;
  }

  .contact-hero-inner {
    display: grid;
    gap: 28px;
    align-items: center;
  }

  @media (min-width: 980px) {
    .contact-hero-inner {
      grid-template-columns: 1.08fr 0.92fr;
    }
  }

  .contact-copy {
    max-width: 760px;
  }

  .contact-copy h1 {
    margin-top: 10px;
    margin-bottom: 16px;
    max-width: 11ch;
  }

  .contact-lead {
    max-width: 54ch;
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(28,39,51,.82);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .contact-main-cta {
    min-width: 240px;
  }

  .contact-points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    margin-top: 18px;
    color: var(--primary);
    font-size: .95rem;
    font-weight: 700;
  }

  .contact-highlight {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 26px;
  }

  .contact-highlight-badge {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: var(--primary-soft);
    color: var(--primary);
    font-size: 0.88rem;
    font-weight: 800;
    margin-bottom: 14px;
  }

  .contact-highlight h2 {
    margin-bottom: 18px;
    font-size: clamp(1.7rem, 2.4vw, 2.4rem);
  }

  .contact-mini-steps {
    display: grid;
    gap: 12px;
  }

  .contact-mini-step {
    padding: 16px 18px;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.84);
  }

  .contact-mini-step strong {
    display: block;
    margin-bottom: 6px;
    font-size: 1rem;
    color: var(--ink);
  }

  .contact-mini-step p {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .simple-steps {
    display: grid;
    gap: 18px;
  }

  @media (min-width: 900px) {
    .simple-steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .simple-step {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: 24px;
  }

  .simple-step-number {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--primary-soft);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .simple-step h3 {
    margin-bottom: 8px;
  }

  .simple-step p {
    margin: 0;
    color: var(--muted);
  }

  .contact-direct-grid {
    display: grid;
    gap: 18px;
  }

  @media (min-width: 900px) {
    .contact-direct-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .direct-card {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 26px;
    text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .direct-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .direct-card-primary {
    border-color: rgba(94,168,93,.24);
    background: linear-gradient(180deg, #ffffff 0%, var(--primary-soft) 100%);
  }

  .direct-label {
    display: inline-block;
    margin-bottom: 10px;
    color: var(--primary);
    font-size: .82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .direct-card h3 {
    margin-bottom: 8px;
  }

  .direct-card p {
    margin: 0;
    color: var(--muted);
    max-width: 38ch;
  }

  .contact-note-box {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 22px 24px;
    max-width: 780px;
  }

  .contact-note-box p {
    margin: 0;
    color: rgba(28,39,51,.84);
    line-height: 1.75;
  }

  @media (max-width: 720px) {
    .contact-hero {
      padding: 42px 0 18px;
    }

    .contact-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .contact-main-cta {
      min-width: 0;
    }

    .contact-highlight,
    .simple-step,
    .direct-card,
    .contact-note-box {
      padding: 22px;
      border-radius: 22px;
    }

    .contact-points {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>