---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import FAQ from "../components/FAQ.astro";

import "../styles/global.css";
---

<BaseLayout
  title="Entrümpelung & Haushaltsauflösung Hannover | Schnell & fair"
  description="Entrümpelung und Haushaltsauflösung in Hannover. Schnell, zuverlässig und besenrein. Jetzt kostenloses Angebot per WhatsApp anfragen."
/>

  <Header />

<Hero
  title="Entrümpelung in Hannover – schnell & stressfrei."
  subtitle="Haushaltsauflösungs Helfer Hannover übernimmt Entrümpelungen und Haushaltsauflösungen in Hannover und Umgebung – zuverlässig, diskret und besenrein. Du bekommst ein transparentes Festpreis-Angebot nach Fotos oder Besichtigung."
  bullets={[
    "Hannover + 20 km Umkreis",
    "Kurzfristige Termine möglich",
    "Besenrein & ordentlich",
    "Festpreis nach Fotos oder Besichtigung"
  ]}
/>
<Section kicker="Hannover & Umgebung" heading="Entrümpelung und Haushaltsauflösung in Hannover">
  <div class="local-seo">
    <div class="local-seo-copy">
      <p>
        Wir bieten professionelle <strong>Entrümpelungen in Hannover</strong> sowie
        <strong>Haushaltsauflösungen in Hannover</strong> und Umgebung an. Egal ob
        Wohnung, Haus, Keller oder Dachboden – wir kümmern uns zuverlässig,
        schnell und besenrein um die komplette Räumung.
      </p>

      <p>
        Unsere Leistungen richten sich an Privatpersonen und Gewerbe. Ob einzelne
        Räume oder komplette Haushaltsauflösungen – wir planen sauber, arbeiten
        strukturiert und sorgen für eine stressfreie Abwicklung.
      </p>
    </div>

    <aside class="local-seo-box">
      <div class="local-seo-badge">Einsatzgebiet</div>

      <h3>In Hannover und Umgebung für dich im Einsatz</h3>

      <p>
        Unter anderem in <strong>Linden, List, Bothfeld, Misburg</strong>,
        <strong>Laatzen</strong> sowie weiteren Stadtteilen rund um Hannover.
      </p>

      <ul class="local-seo-list">
        <li>Wohnungen & Häuser</li>
        <li>Keller & Dachböden</li>
        <li>Privat & Gewerbe</li>
      </ul>
    </aside>
  </div>
</Section>


  <Section kicker="Leistungen" heading="Wobei wir helfen">
  <div class="services-grid">

    <div class="service-card">
      <div class="service-icon">🏠</div>
      <h3>Entrümpelung</h3>
      <p>Keller, Dachboden, Garage oder komplette Wohnung – wir räumen alles zuverlässig und besenrein.</p>
    </div>

    <div class="service-card">
      <div class="service-icon">📦</div>
      <h3>Haushaltsauflösung</h3>
      <p>Diskret und respektvoll – ideal bei Umzug, Nachlass oder sensiblen Situationen.</p>
    </div>

    <div class="service-card">
      <div class="service-icon">🏢</div>
      <h3>Gewerbe</h3>
      <p>Büro, Lager oder Praxis – schnell, planbar und mit klaren Zeitfenstern.</p>
    </div>

  </div>
</Section>

 <Section kicker="Transparenz" heading="So läuft die Kalkulation ab">
  <div class="process">

    <div class="process-step">
      <div class="step-number">1</div>
      <h3>Fotos senden</h3>
      <p>Du schickst uns Bilder oder Infos zur Entrümpelung – ganz unkompliziert per WhatsApp oder Formular.</p>
    </div>

    <div class="process-step">
      <div class="step-number">2</div>
      <h3>Festpreis erhalten</h3>
      <p>Wir schätzen Aufwand und Volumen und geben dir ein klares, faires Festpreis-Angebot.</p>
    </div>

    <div class="process-step">
      <div class="step-number">3</div>
      <h3>Optional: Besichtigung</h3>
      <p>Wenn nötig, schauen wir uns alles vor Ort an – kostenlos und unverbindlich.</p>
    </div>

    <div class="process-step highlight">
      <div class="step-number">✓</div>
      <h3>Wertanrechnung möglich</h3>
      <p>Verwertbare Gegenstände können angerechnet werden – das senkt deinen Preis.</p>
    </div>

  </div>

  <div class="process-cta">
    <a class="btn-primary" href="/kontakt">Kostenloses Angebot anfragen</a>
  </div>
</Section>

<Section kicker="Warum wir?" heading="Darauf kannst du dich verlassen">
  <div class="trust-grid">

    <div class="trust-item">
      <div class="trust-icon">🇩🇪</div>
      <h3>Klare Kommunikation</h3>
      <p>Keine Sprachbarrieren – wir sprechen fließend Deutsch und klären alles verständlich und direkt.</p>
    </div>

    <div class="trust-item">
      <div class="trust-icon">⚡</div>
      <h3>Schnelle Termine</h3>
      <p>Kurzfristige Einsätze möglich – wir reagieren schnell und flexibel auf deine Anfrage.</p>
    </div>

    <div class="trust-item">
      <div class="trust-icon">⏱</div>
      <h3>Pünktlich & zuverlässig</h3>
      <p>Wir erscheinen zum vereinbarten Zeitpunkt und halten uns an Absprachen.</p>
    </div>

    <div class="trust-item">
      <div class="trust-icon">🧹</div>
      <h3>Gründlich & sauber</h3>
      <p>Wir arbeiten sorgfältig und übergeben alles besenrein und ordentlich.</p>
    </div>

    <div class="trust-item">
      <div class="trust-icon">💰</div>
      <h3>Faire Festpreise</h3>
      <p>Du bekommst transparente Preise – ohne versteckte Kosten oder Überraschungen.</p>
    </div>

    <div class="trust-item">
      <div class="trust-icon">🤝</div>
      <h3>Respektvoller Umgang</h3>
      <p>Besonders bei sensiblen Situationen arbeiten wir diskret und mit dem nötigen Feingefühl.</p>
    </div>

  </div>
</Section>

  <Section kicker="FAQ" heading="Häufige Fragen">
    <FAQ />
  </Section>

  <Footer />
</BaseLayout>

<style>.services-grid{
  display:grid;
  gap:20px;
}

@media (min-width: 900px){
  .services-grid{
    grid-template-columns: repeat(3, 1fr);
  }
}

.service-card{
  padding: 22px;
  border-radius: var(--radius);
  background: var(--card);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
  transition: .25s;
}

.service-card:hover{
  transform: translateY(-4px);
  box-shadow: var(--shadow);
}

.service-icon{
  font-size: 1.6rem;
  margin-bottom: 10px;
}

.service-card h3{
  margin: 6px 0 8px;
}

.service-card p{
  font-size: .98rem;
  color: var(--muted);
}
.process{
  display:grid;
  gap:18px;
}

@media (min-width: 900px){
  .process{
    grid-template-columns: repeat(4, 1fr);
  }
}

.process-step{
  padding: 20px;
  border-radius: var(--radius);
  background: var(--card);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
  transition: .25s;
}

.process-step:hover{
  transform: translateY(-3px);
  box-shadow: var(--shadow);
}

.step-number{
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--primary-soft);
  color: var(--primary);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight: 800;
  margin-bottom: 10px;
}

.process-step h3{
  margin-bottom: 8px;
}

.process-step p{
  font-size: .95rem;
  color: var(--muted);
}

/* Highlight */
.process-step.highlight{
  background: var(--primary-soft);
  border: 1px solid rgba(94,168,93,.25);
}

/* CTA */
.process-cta{
  margin-top: 24px;
  display:flex;
  gap:12px;
  flex-wrap:wrap;
}
.trust-grid{
  display:grid;
  gap:18px;
}

@media (min-width: 900px){
  .trust-grid{
    grid-template-columns: repeat(3, 1fr);
  }
}

.trust-item{
  padding:22px;
  border-radius: var(--radius);
  background: var(--card);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
  transition:.25s;
}

.trust-item:hover{
  transform: translateY(-4px);
  box-shadow: var(--shadow);
}

.trust-icon{
  font-size: 1.4rem;
  margin-bottom: 10px;
}

.trust-item h3{
  margin-bottom: 8px;
}

.trust-item p{
  font-size: .95rem;
  color: var(--muted);
}

  .btn-primary,
  .btn-secondary {
    width: 100%;
    text-align: center;
  }
  
  /* BUTTONS */
.btn-primary {
  padding: 14px 22px;
  border-radius: 999px;
  background: var(--primary);
  color: white;
  font-weight: 700;
  text-decoration: none;
  max-width: fit-content;
}

.btn-secondary {
  padding: 14px 22px;
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,0.1);
  text-decoration: none;
  color: #1d2733;
  font-weight: 600;
}

.local-seo{
  display:grid;
  gap:24px;
  align-items:start;
  margin-bottom: 40px;
}

@media (min-width: 980px){
  .local-seo{
    grid-template-columns: 1.08fr 0.92fr;
    
  }
}

.local-seo-copy{
  max-width: 640px;
}

.local-seo-copy p{
  margin: 0 0 16px;
  line-height: 1.75;
  color: rgba(28,39,51,.85);
}

.local-seo-box{
  background:#fff;
  border:1px solid var(--line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding:24px;
}

.local-seo-badge{
  display:inline-flex;
  align-items:center;
  min-height:34px;
  padding:0.45rem 0.8rem;
  border-radius:999px;
  background: rgba(94,168,93,0.14);
  color: var(--primary);
  font-size:.88rem;
  font-weight:800;
  margin-bottom:14px;
}

.local-seo-box h3{
  margin-bottom:10px;
}

.local-seo-box p{
  margin:0 0 14px;
  color: var(--muted);
  line-height:1.65;
}

.local-seo-list{
  margin:0;
  padding-left:1.1rem;
  display:grid;
  gap:8px;
  color: var(--ink);
}

@media (max-width: 720px){
  .local-seo-box{
    padding:22px;
    border-radius:22px;
  }
}
</style>